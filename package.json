{
  "name": "mcp-sidra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Remote MCP server for public IBGE SIDRA data, prepared for ChatGPT Apps SDK.",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "inspect": "npx @modelcontextprotocol/inspector@latest --server-url http://localhost:8788/mcp --transport http"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
